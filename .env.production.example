# SpotLight Production Environment Variables
# Copy relevant variables from .env.example and set production values
# CRITICAL: Never commit the actual .env file - only use this template

# =======================
# REQUIRED FOR PRODUCTION
# =======================

# Django Core Settings
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-long-random-secret-key-here-change-this

# Set to False in production
DEBUG=False

# Your production domain(s)
ALLOWED_HOSTS=spotlight-api.onrender.com,yourdomain.com,www.yourdomain.com

# =======================
# DATABASE (PostgreSQL)
# =======================

# Option 1: Use DATABASE_URL (Render.com)
# This is automatically set by Render, just verify it's there
DATABASE_URL=postgresql://user:password@host:5432/spotlight_db

# Option 2: Manual Database Configuration
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=spotlight_db
# DB_USER=postgres
# DB_PASSWORD=your-strong-database-password
# DB_HOST=your-postgres-host.onrender.com
# DB_PORT=5432

# =======================
# CORS & SECURITY
# =======================

# Frontend domain(s) - required for API requests
CORS_ALLOWED_ORIGINS=https://spotlight-frontend.onrender.com,https://yourdomain.com,https://www.yourdomain.com

# =======================
# JWT AUTHENTICATION
# =======================

JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256

# =======================
# PAYPAL INTEGRATION
# =======================

# Set to 'live' when switching to production payments
PAYPAL_MODE=sandbox

# Get from: https://developer.paypal.com/dashboard/
# Sandbox app credentials (for testing)
PAYPAL_CLIENT_ID=your_sandbox_client_id_here
PAYPAL_CLIENT_SECRET=your_sandbox_client_secret_here

# Production credentials (when ready to accept real payments)
# PAYPAL_CLIENT_ID=your_production_client_id_here
# PAYPAL_CLIENT_SECRET=your_production_client_secret_here

# PayPal Callback URLs - update with your production domain
PAYPAL_RETURN_URL=https://spotlight-frontend.onrender.com/subscription/success
PAYPAL_CANCEL_URL=https://spotlight-frontend.onrender.com/subscription/cancel

# =======================
# AWS S3 (Optional - for file uploads)
# =======================

# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_STORAGE_BUCKET_NAME=spotlight-parking-prod
# AWS_S3_REGION_NAME=us-east-1

# =======================
# EMAIL CONFIGURATION (Optional - for notifications)
# =======================

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-specific-password

# =======================
# LOGGING & MONITORING (Optional)
# =======================

# SENTRY_DSN=your_sentry_dsn_for_error_tracking

# =======================
# FRONTEND ENVIRONMENT
# =======================

# Frontend needs these variables at build time:
# REACT_APP_API_URL=https://spotlight-api.onrender.com/api
# REACT_APP_PAYPAL_CLIENT_ID=your_paypal_client_id_here
